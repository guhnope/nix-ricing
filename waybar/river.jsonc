{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 8,

  // 1. Updated modules list
  "modules-left": ["custom/launcher", "river/tags", "river/window"],
  "modules-center": ["clock"],
  "modules-right": [
    "tray",
    "custom/wallpaper",
    "custom/screenshot",
    "custom/cliphist",
    "custom/notification",
    "pulseaudio",
    "network",
    "custom/power",
  ],

  // 2. River Tags Module
  "river/tags": {
    "num-tags": 5,
    "tag-labels": ["1", "2", "3", "4", "5"],
  },

  // 3. River Window Module
  "river/window": {
    "format": " 󰖲 {title} ",
    "max-length": 40,
  },

  "custom/launcher": {
    "format": "  ", // NixOS / Nerd Font icon
    "on-click": "fuzzel",
    "tooltip": false,
  },

  "clock": {
    "format": "{:%H:%M  |  %A, %B %d}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "󰝟 Muted",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"],
    },
    "on-click": "pavucontrol",
  },

  "network": {
    "format-wifi": "   {essid}",
    "format-ethernet": "󰈀 ",
    "format-disconnected": "󰖪 ",
    "tooltip-format": "{ifname} via {gwaddr}",
  },

  "tray": {
    "icon-size": 21,
    "spacing": 10,
  },

  "custom/cliphist": {
    "format": " ",
    "tooltip": false,
    "on-click": "cliphist list | fuzzel --dmenu | cliphist decode | wl-copy",
  },

  "custom/wallpaper": {
    "format": "",
    "tooltip": false,
    "on-click": "waypaper --backend awww --random",
  },

  "custom/notification": {
    "format": " ",
    "tooltip": false,
    "on-click": "makoctl dismiss",
  },

  "custom/screenshot": {
    "format": "  ",
    "tooltip": false,
    "on-click": "grimshot savecopy area",
    "on-click-right": "grimshot savecopy screen",
  },

  "custom/power": {
    "format": "⏻  ",
    "tooltip": false,
    "on-click": "wlogout --protocol layer-shell --buttons-per-row 4",
  },
}
